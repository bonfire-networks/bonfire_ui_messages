<main class="h-full flex flex-1 w-full overflow-hidden bonfire-wrapper">
  <Bonfire.UI.Messages.MessageThreadsLive
    showing_within={:messages}
    context={current_user_id(@__context__)}
    threads={@threads}
    thread_id={@thread_id}
    filter_tab={@filter_tab}
    search_term={@search_term}
    composing_new={e(@composing_new, false)}
    selected_recipients={e(@selected_recipients, [])}
  />
</main>
